<script>
const S = getState();

// Redirect guard
if (!S.service || !S.date || !S.time) {
  location.href = 'book.html';
}

// Populate booking pill
document.getElementById('bpIcon').textContent = S.serviceIcon || '🧘';
document.getElementById('bpName').textContent = S.service || '—';
document.getElementById('bpMeta').textContent = `${S.dur || '—'} · ${formatDate(S.date)} · ${S.time || '—'}`;
document.getElementById('bpPrice').textContent = `RM ${S.price || '—'}`;

// Restore saved inputs
if (S.fname) document.getElementById('fname').value = S.fname;
if (S.lname) document.getElementById('lname').value = S.lname;
if (S.phone) document.getElementById('phone').value = S.phone;
if (S.email) document.getElementById('email').value = S.email;
if (S.notes) document.getElementById('notes').value = S.notes;
if (S.isMember) document.getElementById('memberCb').checked = true;
if (S.promo) {
  document.getElementById('promoIn').value = S.promo;
  const p = PROMOS[S.promo];
  if (p) {
    document.getElementById('promoMsg').className = 'promo-msg promo-ok';
    document.getElementById('promoMsg').textContent = `✓ ${p.label}`;
  }
}
if (S.payment) {
  document.querySelectorAll('.pay-opt').forEach(el => {
    el.classList.toggle('sel', el.querySelector('.pay-name').textContent === S.payment);
  });
}

function applyPromo() {
  const code = document.getElementById('promoIn').value.toUpperCase().trim();
  const msg  = document.getElementById('promoMsg');
  if (PROMOS[code]) {
    const p = PROMOS[code];
    setState({ promo: code, promoDisc: p.val, promoType: p.type });
    msg.className = 'promo-msg promo-ok';
    msg.textContent = `✓ ${p.label} applied!`;
    showToast('Promo code applied! 🎉');
  } else if (!code) {
    setState({ promo: null, promoDisc: 0 });
    msg.textContent = '';
  } else {
    setState({ promo: null, promoDisc: 0 });
    msg.className = 'promo-msg promo-err';
    msg.textContent = '✗ Invalid code. Try THAIZEN20';
  }
}

function toggleMember() {
  const cb = document.getElementById('memberCb');
  cb.checked = !cb.checked;
  setState({ isMember: cb.checked });
  if (cb.checked) showToast('Member perks activated ✦ 🌟');
}

function selectPay(el) {
  document.querySelectorAll('.pay-opt').forEach(p => p.classList.remove('sel'));
  el.classList.add('sel');
  setState({ payment: el.querySelector('.pay-name').textContent });
}

function proceed() {
  const fname = document.getElementById('fname').value.trim();
  const lname = document.getElementById('lname').value.trim();
  const phone = document.getElementById('phone').value.trim();
  const email = document.getElementById('email').value.trim();
  if (!fname) { showToast('Please enter your first name'); return; }
  if (!phone) { showToast('Please enter your mobile number'); return; }
  if (!email || !email.includes('@')) { showToast('Please enter a valid email address'); return; }
  setState({
    fname, lname, phone, email,
    notes: document.getElementById('notes').value.trim(),
    isMember: document.getElementById('memberCb').checked,
  });
  location.href = 'confirm.html';
}
</script>
</body>
