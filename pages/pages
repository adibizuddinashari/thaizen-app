<script src="../js/app.js"></script>
<script>
const S = getState();
if (!S.ref) {
  // Generate ref if landed directly
  setState({ ref: generateRef(), finalPrice: S.price });
}
const ref = S.ref || generateRef();

document.getElementById('refCode').textContent   = ref;
document.getElementById('dSvc').textContent     = S.service || '—';
document.getElementById('dDT').textContent      = `${formatDate(S.date)} · ${S.time || '—'}`;
document.getElementById('dDur').textContent     = S.dur || '—';
document.getElementById('dGuest').textContent   = `${S.fname || ''} ${S.lname || ''}`.trim() || '—';
document.getElementById('dTotal').textContent   = `RM ${S.finalPrice || S.price || '—'}`;
document.getElementById('dEmail').textContent   = S.email || 'your email';

// Save to mock bookings list
try {
  const history = JSON.parse(localStorage.getItem('thaizen_bookings') || '[]');
  history.unshift({
    ref, service: S.service, icon: S.serviceIcon,
    date: S.date, time: S.time, dur: S.dur,
    guest: `${S.fname} ${S.lname}`.trim(),
    total: S.finalPrice || S.price,
    status: 'confirmed', createdAt: new Date().toISOString()
  });
  localStorage.setItem('thaizen_bookings', JSON.stringify(history.slice(0, 20)));
} catch {}

function addCal() { showToast('📅 Calendar integration — coming in Phase 2!'); }
function share()  {
  if (navigator.share) {
    navigator.share({ title: 'My Thaizen Booking', text: `Booking ref: ${ref} — ${S.service} on ${formatDate(S.date)} at ${S.time}` });
  } else { showToast('Copy your ref: ' + ref); }
}
function goHome() { clearState(); location.href = '../index.html'; }
</script>
